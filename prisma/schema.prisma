generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Admin {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      String   @default("admin")
  status    String   @default("Active")
  createdAt DateTime @default(now())
}

model Notice {
  id          String   @id @default(cuid())
  title       String
  description String
  category    String
  isPublished Boolean  @default(false)
  createdBy   String   @default("")
  updatedBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isPublished, createdAt])
}

model Event {
  id          String   @id @default(cuid())
  title       String
  description String
  image       String?
  eventDate   DateTime
  category    String
  isPublished Boolean  @default(false)
  createdBy   String   @default("")
  updatedBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isPublished, eventDate])
}

model Gallery {
  id        String   @id @default(cuid())
  title     String
  imageUrl  String
  category  String
  createdBy String   @default("")
  updatedBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Achiever {
  id               String   @id @default(cuid())
  studentName      String   @map("name")
  className        String
  percentage       Float
  academicSession  Int      @map("year")
  rank             Int      @default(0)
  photoUrl         String?  @map("photo")
  achievementTitle String   @default("")
  isPublished      Boolean  @default(false)
  createdBy        String   @default("")
  updatedBy        String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([academicSession, rank])
  @@index([isPublished])
  @@map("achievers")
}

model Teacher {
  id              String   @id @default(cuid())
  employeeId      String   @unique
  teacherName     String
  email           String   @unique
  phone           String
  subject         String
  assignedClasses String   @default("")
  password        String?
  joiningDate     DateTime
  qualification   String
  address         String
  photoUrl        String?
  status          String   @default("Active")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  homework           Homework[]
  classTeachers      ClassTeacher[]
  subjectAssignments SubjectAssignment[]

  @@index([subject])
  @@index([status])
}

model Student {
  id              String       @id @default(cuid())
  admissionNumber String       @unique
  studentName     String
  fatherName      String
  motherName      String
  mobileNumber    String
  alternateMobile String       @default("")
  dateOfBirth     DateTime
  gender          String       @default("")
  className       String
  section         String
  address         String
  admissionDate   DateTime
  status          String       @default("Active")
  photoUrl        String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  attendance      Attendance[]
  results         Result[]
  parent          Parent?

  @@index([className, section])
  @@index([status])
}

model Attendance {
  id             String   @id @default(cuid())
  studentId      String
  teacherId      String
  className      String
  section        String
  attendanceDate DateTime
  status         String
  remarks        String   @default("")
  createdAt      DateTime @default(now())

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, attendanceDate])
  @@index([className, section, attendanceDate])
  @@index([attendanceDate])
}

model SchoolClass {
  id        String   @id @default(cuid())
  className String   @unique
  status    String   @default("Active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  homework           Homework[]
  classTeachers      ClassTeacher[]
  subjectAssignments SubjectAssignment[]
}

model Section {
  id          String @id @default(cuid())
  sectionName String @unique
  status      String @default("Active")

  homework           Homework[]
  classTeachers      ClassTeacher[]
  subjectAssignments SubjectAssignment[]
}

model Subject {
  id          String @id @default(cuid())
  subjectName String @unique
  subjectCode String @default("")
  status      String @default("Active")

  homework           Homework[]
  subjectAssignments SubjectAssignment[]
  results            Result[]
}

model ClassTeacher {
  id        String @id @default(cuid())
  classId   String
  sectionId String
  teacherId String @unique

  class   SchoolClass @relation(fields: [classId], references: [id], onDelete: Cascade)
  section Section     @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  teacher Teacher     @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@unique([classId, sectionId])
}

model SubjectAssignment {
  id        String @id @default(cuid())
  classId   String
  sectionId String
  subjectId String
  teacherId String

  class   SchoolClass @relation(fields: [classId], references: [id], onDelete: Cascade)
  section Section     @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  subject Subject     @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  teacher Teacher     @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@unique([classId, sectionId, subjectId])
  @@index([classId, sectionId])
  @@index([teacherId])
}

model Homework {
  id            String   @id @default(cuid())
  title         String
  description   String
  subjectId     String
  teacherId     String
  classId       String
  sectionId     String
  dueDate       DateTime
  attachmentUrl String?
  status        String   @default("published")
  createdAt     DateTime @default(now())

  subject Subject     @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  teacher Teacher     @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  class   SchoolClass @relation(fields: [classId], references: [id], onDelete: Cascade)
  section Section     @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@index([classId, sectionId])
  @@index([teacherId])
  @@index([subjectId])
  @@index([dueDate])
}

model Parent {
  id           String   @id @default(cuid())
  fatherName   String
  motherName   String
  mobileNumber String   @unique
  email        String   @default("")
  password     String
  student      Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  studentId    String   @unique
  status       String   @default("Active")
  createdAt    DateTime @default(now())

  @@index([mobileNumber])
}

model Exam {
  id              String   @id @default(cuid())
  examName        String
  academicSession Int
  examType        String
  startDate       DateTime
  endDate         DateTime
  isPublished     Boolean  @default(false)
  createdBy       String   @default("")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  results Result[]

  @@index([academicSession])
  @@index([examType])
  @@index([isPublished])
}

model Result {
  id            String   @id @default(cuid())
  studentId     String
  examId        String
  subjectId     String
  marksObtained Float
  maximumMarks  Float
  grade         String   @default("")
  remarks       String   @default("")

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  exam    Exam    @relation(fields: [examId], references: [id], onDelete: Cascade)
  subject Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@unique([studentId, examId, subjectId])
  @@index([examId])
  @@index([studentId, examId])
  @@index([examId, subjectId])
}

model Notification {
  id        String   @id @default(cuid())
  type      String
  title     String
  message   String
  parentId  String?
  studentId String?
  classId   String?
  sectionId String?
  sentBy    String   @default("")
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([parentId])
  @@index([studentId])
  @@index([classId, sectionId])
  @@index([createdAt])
}

model AcademicSession {
  id        String   @id @default(cuid())
  name      String   @unique
  startYear Int      @unique
  endYear   Int
  isActive  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
}

model SystemSetting {
  id    String @id @default(cuid())
  key   String @unique
  value String
}

model AuditLog {
  id        String   @id @default(cuid())
  action    String
  entity    String
  entityId  String?
  adminId   String?
  adminName String   @default("")
  details   String?
  ipAddress String?
  createdAt DateTime @default(now())

  @@index([entity, createdAt])
  @@index([adminId])
  @@index([createdAt])
}

model Promotion {
  id              String   @id @default(cuid())
  fromClass       String
  toClass         String
  academicSession Int
  studentCount    Int
  details         String   @default("")
  createdBy       String   @default("")
  createdAt       DateTime @default(now())
}
