generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Admin {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      String   @default("admin")
  status    String   @default("Active")
  createdAt DateTime @default(now())
}

model Notice {
  id          String     @id @default(cuid())
  title       String
  description String
  category    String
  isPublished Boolean    @default(false)
  createdBy   String     @default("")
  updatedBy   String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Event {
  id          String     @id @default(cuid())
  title       String
  description String
  image       String?
  eventDate   DateTime
  category    String
  isPublished Boolean    @default(false)
  createdBy   String     @default("")
  updatedBy   String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Gallery {
  id        String     @id @default(cuid())
  title     String
  imageUrl  String
  category  String
  createdBy String     @default("")
  updatedBy String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model Achiever {
  id               String   @id @default(cuid())
  studentName      String   @map("name")
  className        String
  percentage       Float
  academicSession  Int      @map("year")
  rank             Int      @default(0)
  photoUrl         String?  @map("photo")
  achievementTitle String   @default("")
  isPublished      Boolean  @default(false)
  createdBy        String   @default("")
  updatedBy        String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("achievers")
}

model Teacher {
  id              String   @id @default(cuid())
  employeeId      String   @unique
  teacherName     String
  email           String
  phone           String
  subject         String
  assignedClasses String   @default("")
  password        String?
  joiningDate     DateTime
  qualification   String
  address         String
  photoUrl        String?
  status          String   @default("Active")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Student {
  id               String       @id @default(cuid())
  admissionNumber  String       @unique
  studentName      String
  fatherName       String
  motherName       String
  mobileNumber     String
  alternateMobile  String       @default("")
  dateOfBirth      DateTime
  gender           String       @default("")
  className        String
  section          String
  address          String
  admissionDate    DateTime
  status           String       @default("Active")
  photoUrl         String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  attendance       Attendance[]
}

model Attendance {
  id              String   @id @default(cuid())
  studentId       String
  teacherId       String
  className       String
  section         String
  attendanceDate  DateTime
  status          String
  remarks         String   @default("")
  createdAt       DateTime @default(now())

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, attendanceDate])
  @@index([className, section, attendanceDate])
  @@index([attendanceDate])
}

model Homework {
  id            String   @id @default(cuid())
  title         String
  description   String
  subject       String
  className     String
  section       String
  dueDate       DateTime
  attachmentUrl String?
  createdBy     String
  createdAt     DateTime @default(now())

  @@index([className, section])
  @@index([subject])
  @@index([dueDate])
}
