generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Admin {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      String   @default("admin")
  status    String   @default("Active")
  createdAt DateTime @default(now())
}

model Notice {
  id          String     @id @default(cuid())
  title       String
  description String
  category    String
  isPublished Boolean    @default(false)
  createdBy   String     @default("")
  updatedBy   String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Event {
  id          String     @id @default(cuid())
  title       String
  description String
  image       String?
  eventDate   DateTime
  category    String
  isPublished Boolean    @default(false)
  createdBy   String     @default("")
  updatedBy   String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Gallery {
  id        String     @id @default(cuid())
  title     String
  imageUrl  String
  category  String
  createdBy String     @default("")
  updatedBy String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model Achiever {
  id               String   @id @default(cuid())
  studentName      String   @map("name")
  className        String
  percentage       Float
  academicSession  Int      @map("year")
  rank             Int      @default(0)
  photoUrl         String?  @map("photo")
  achievementTitle String   @default("")
  isPublished      Boolean  @default(false)
  createdBy        String   @default("")
  updatedBy        String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("achievers")
}

model Teacher {
  id              String   @id @default(cuid())
  employeeId      String   @unique
  teacherName     String
  email           String
  phone           String
  subject         String
  assignedClasses String   @default("")
  password        String?
  joiningDate     DateTime
  qualification   String
  address         String
  photoUrl        String?
  status          String   @default("Active")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  homework             Homework[]
  classTeachers        ClassTeacher[]
  subjectAssignments   SubjectAssignment[]
}

model Student {
  id               String       @id @default(cuid())
  admissionNumber  String       @unique
  studentName      String
  fatherName       String
  motherName       String
  mobileNumber     String
  alternateMobile  String       @default("")
  dateOfBirth      DateTime
  gender           String       @default("")
  className        String
  section          String
  address          String
  admissionDate    DateTime
  status           String       @default("Active")
  photoUrl         String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  attendance       Attendance[]
  parent           Parent?
}

model Attendance {
  id              String   @id @default(cuid())
  studentId       String
  teacherId       String
  className       String
  section         String
  attendanceDate  DateTime
  status          String
  remarks         String   @default("")
  createdAt       DateTime @default(now())

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, attendanceDate])
  @@index([className, section, attendanceDate])
  @@index([attendanceDate])
}

model SchoolClass {
  id        String   @id @default(cuid())
  className String   @unique
  status    String   @default("Active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  homework             Homework[]
  classTeachers        ClassTeacher[]
  subjectAssignments   SubjectAssignment[]
}

model Section {
  id          String @id @default(cuid())
  sectionName String @unique
  status      String @default("Active")

  homework             Homework[]
  classTeachers        ClassTeacher[]
  subjectAssignments   SubjectAssignment[]
}

model Subject {
  id          String @id @default(cuid())
  subjectName String @unique
  subjectCode String @default("")
  status      String @default("Active")

  homework             Homework[]
  subjectAssignments   SubjectAssignment[]
}

model ClassTeacher {
  id        String   @id @default(cuid())
  classId   String
  sectionId String
  teacherId String   @unique

  class   SchoolClass @relation(fields: [classId], references: [id], onDelete: Cascade)
  section Section     @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  teacher Teacher     @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@unique([classId, sectionId])
}

model SubjectAssignment {
  id        String @id @default(cuid())
  classId   String
  sectionId String
  subjectId String
  teacherId String

  class   SchoolClass @relation(fields: [classId], references: [id], onDelete: Cascade)
  section Section     @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  subject Subject     @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  teacher Teacher     @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@unique([classId, sectionId, subjectId])
  @@index([classId, sectionId])
  @@index([teacherId])
}

model Homework {
  id            String   @id @default(cuid())
  title         String
  description   String
  subjectId     String
  teacherId     String
  classId       String
  sectionId     String
  dueDate       DateTime
  attachmentUrl String?
  status        String   @default("published")
  createdAt     DateTime @default(now())

  subject Subject     @relation(fields: [subjectId], references: [id])
  teacher Teacher     @relation(fields: [teacherId], references: [id])
  class   SchoolClass @relation(fields: [classId], references: [id])
  section Section     @relation(fields: [sectionId], references: [id])

  @@index([classId, sectionId])
  @@index([teacherId])
  @@index([subjectId])
  @@index([dueDate])
}

model Parent {
  id           String   @id @default(cuid())
  fatherName   String
  motherName   String
  mobileNumber String   @unique
  email        String   @default("")
  password     String
  student      Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  studentId    String   @unique
  status       String   @default("Active")
  createdAt    DateTime @default(now())
}

model Notification {
  id        String   @id @default(cuid())
  type      String
  title     String
  message   String
  parentId  String?
  studentId String?
  classId   String?
  sectionId String?
  sentBy    String   @default("")
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([parentId])
  @@index([studentId])
  @@index([classId, sectionId])
  @@index([createdAt])
}
