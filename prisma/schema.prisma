generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Admin {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      String   @default("super_admin")
  createdAt DateTime @default(now())
}

model Notice {
  id          String   @id @default(cuid())
  title       String
  description String
  category    String
  createdAt   DateTime @default(now())
}

model Event {
  id          String   @id @default(cuid())
  title       String
  description String
  image       String?
  eventDate   DateTime
  category    String
  createdAt   DateTime @default(now())
}

model Gallery {
  id        String   @id @default(cuid())
  title     String
  image     String
  category  String
  createdAt DateTime @default(now())
}

model Achiever {
  id         String   @id @default(cuid())
  name       String
  className  String
  percentage Float
  photo      String?
  year       Int
  createdAt  DateTime @default(now())
}

model Student {
  id               String   @id @default(cuid())
  admissionNumber  String   @unique
  studentName      String
  fatherName       String
  motherName       String
  mobileNumber     String
  className        String
  section          String
  dateOfBirth      DateTime
  address          String
  status           String   @default("Active")
  admissionDate    DateTime
  createdAt        DateTime @default(now())
}
