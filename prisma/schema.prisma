generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Admin {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      String   @default("admin")
  status    String   @default("Active")
  createdAt DateTime @default(now())
}

model Notice {
  id          String     @id @default(cuid())
  title       String
  description String
  category    String
  isPublished Boolean    @default(false)
  createdBy   String     @default("")
  updatedBy   String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Event {
  id          String     @id @default(cuid())
  title       String
  description String
  image       String?
  eventDate   DateTime
  category    String
  isPublished Boolean    @default(false)
  createdBy   String     @default("")
  updatedBy   String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Gallery {
  id        String     @id @default(cuid())
  title     String
  imageUrl  String
  category  String
  createdBy String     @default("")
  updatedBy String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model Achiever {
  id               String   @id @default(cuid())
  studentName      String   @map("name")
  className        String
  percentage       Float
  academicSession  Int      @map("year")
  rank             Int      @default(0)
  photoUrl         String?  @map("photo")
  achievementTitle String   @default("")
  isPublished      Boolean  @default(false)
  createdBy        String   @default("")
  updatedBy        String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("achievers")
}

model Student {
  id               String   @id @default(cuid())
  admissionNumber  String   @unique
  studentName      String
  fatherName       String
  motherName       String
  mobileNumber     String
  className        String
  section          String
  dateOfBirth      DateTime
  address          String
  status           String   @default("Active")
  admissionDate    DateTime
  createdAt        DateTime @default(now())
}
